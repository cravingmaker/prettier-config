{
  "name": "@cravingmaker/prettier-config",
  "version": "0.1.11",
  "private": false,
  "description": "Craving Maker's Prettier configuration",
  "keywords": [
    "cravingmaker",
    "prettier",
    "prettier-config",
    "style",
    "code-style",
    "format"
  ],
  "homepage": "https://github.com/cravingmaker/prettier-config#readme",
  "bugs": {
    "url": "https://github.com/cravingmaker/prettier-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cravingmaker/prettier-config.git"
  },
  "license": "MIT",
  "author": "cravingmaker (https://github.com/cravingmaker)",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@cravingmaker/prettier-config",
  "dependencies": {
    "@prettier/plugin-oxc": "0.1.4",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "devDependencies": {
    "@cravingmaker/eslint-config": "0.0.9",
    "@cravingmaker/prettier-config": "0.1.11",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "astro": "6.3.1",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-svelte": "3.5.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.6",
    "svelte": "5.55.5",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "prettier": ">=3.6.0",
    "prettier-plugin-astro": ">=0.14.0",
    "prettier-plugin-svelte": ">=3.5.0",
    "prettier-plugin-tailwindcss": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-astro": {
      "optional": true
    },
    "prettier-plugin-svelte": {
      "optional": true
    },
    "prettier-plugin-tailwindcss": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
