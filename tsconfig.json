{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"lib": ["ES2022"],
		"module": "NodeNext",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"exclude": ["node_modules", "dist", "tests/fixtures"],
	"include": ["**/*.ts"]
}
